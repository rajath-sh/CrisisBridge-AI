# ═══════════════════════════════════════════════════
# CrisisBridge AI — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this to .env and fill in real values
# cp .env.example .env
# ═══════════════════════════════════════════════════

# ── App ──────────────────────────────────────────
APP_NAME=CrisisBridge AI
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# ── Auth (JWT) ───────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database (PostgreSQL) ────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crisisbridge
DB_ECHO=False

# ── Redis ────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL_SECONDS=300

# ── FAISS / Embeddings ──────────────────────────
FAISS_INDEX_PATH=ai_core/data/faiss_index
EMBEDDING_MODEL=gemini-embedding-2
CHUNK_SIZE=1500
CHUNK_OVERLAP=150
TOP_K_RESULTS=5

# ── LLM (Google Gemini) ─────────────────────────
LLM_MODEL=gemini-2.5-flash-lite
LLM_API_KEY=your_gemini_api_key_here
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ── AI Mode Toggles ─────────────────────────────
# Set to False to use real Gemini AI credits
AI_MOCK_MODE=True
# Set to True to use Vertex AI (GCP) instead of AI Studio
AI_USE_VERTEX=False
GCP_PROJECT_ID=your-project-id-here
GCP_LOCATION=us-central1

# ── Session ──────────────────────────────────────
SESSION_MEMORY_SIZE=5

# ── Safety ───────────────────────────────────────
SAFETY_RADIUS_WARNING_METERS=100.0
SAFETY_RADIUS_EVACUATE_METERS=50.0

# ── Logging ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/crisisbridge.log

# ── CORS ─────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]